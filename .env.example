# ==============================
# ViFood-VQA Environment Config
# ==============================

# Google Gemini API Key (for Phase 3: LLM triple extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# Neo4j Connection (for Phase 4: Graph integration)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Optional: Firecrawl API Key (fallback scraper)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Optional: Exa API Key (fallback scraper)
EXA_API_KEY=your_exa_api_key_here
