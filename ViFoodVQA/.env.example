# Supabase Connection (for KG entity extraction from image table)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# Google Gemini API Key (for Phase 3: LLM triple extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# Neo4j Connection (for Phase 4: Graph integration)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
